# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# packaged source archives (produced by package-pack.sh)
*.zip

# local planning/spec docs
seo_spec.md
SEO_PLAN.md
SEO_TODO.md
seo-keywords-report.csv
seo-keywords-report.md

# AI / tool configs (local-only, never commit)
.claude/
.agents/
.codegraph/
.playwright-mcp/
skills-lock.json
CLAUDE-FABLE-5.md
CLAUDE.md
AGENTS.md

# dev screenshots (root-level PNGs are temp debugging assets)
/*.png
